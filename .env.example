# =============================================================================
# PokéTeam Builder — environment template
# Every .env* except this file is git-ignored.
# =============================================================================

# --- Profile / server -------------------------------------------------------
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- CORS -------------------------------------------------------------------
# The single allowed origin for the SPA (no trailing slash).
CORS_ALLOWED_ORIGIN=http://localhost:4200

# --- JWT --------------------------------------------------------------------
JWT_SECRET=
ACCESS_TOKEN_EXPIRATION_MS=900000
REFRESH_TOKEN_EXPIRATION_MS=604800000

# --- Database (read by the Spring app) --------------------------------------
DB_PORT=5433
DB_USER=poketeam
DB_HOST=localhost
DB_NAME=pokemon_sql
DB_PASSWORD=poketeam

# --- Database (read by the Postgres container at first boot) ----------------
POSTGRES_DB=pokemon_sql
POSTGRES_USER=poketeam
POSTGRES_PASSWORD=poketeam

# --- Mail -------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@poketeambuilder.com
# Inbox that receives /api/contact form submissions.
CONTACT_TO=

# --- Password reset ---------------------------------------------------------
# Where the password-reset email points the user to land on the SPA.
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
PASSWORD_RESET_BASE_URL=http://localhost:4200/auth/reset-password/confirm
